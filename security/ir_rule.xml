<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-Company Rule for custom Asian Distributor groups -->
        <record id="rule_asian_distributor_multicompany" model="ir.rule">
            <field name="name">Asian Distributor: Multi-Company Rule</field>
            <field name="model_id" ref="product.model_product_template" />
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('asian_distributor.group_asian_distributor_local_sales')), 
                                         (4, ref('asian_distributor.group_asian_distributor_purchasing_analyst')), 
                                         (4, ref('asian_distributor.group_asian_distributor_manager'))]"/>
        </record>
    </data>
</odoo>
